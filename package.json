{
  "name": "optima-dashboard",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "concurrently \"pnpm dev:node\" \"pnpm dev:browser\"",
    "dev:browser": "pnpm --filter browser dev",
    "build:browser": "pnpm --filter browser build",
    "dev:node": "pnpm --filter @optima/node dev",
    "build:node": "pnpm --filter @optima/node build",
    "prisma:generate": "pnpm --filter @optima/node prisma:generate",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "precommit": "pnpm format && pnpm build",
    "postinstall": "pnpm prisma:generate",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "oxfmt": "^0.17.0",
    "husky": "^9.1.7"
  }
}
