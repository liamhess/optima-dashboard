{
  "name": "optima-dashboard",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:browser": "pnpm --filter browser dev",
    "build:browser": "pnpm --filter browser build",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "precommit": "pnpm format && pnpm build",
    "prepare": "husky"
  },
  "devDependencies": {
    "oxfmt": "^0.17.0",
    "husky": "^9.1.7"
  }
}
